# =============================================
#   Discord Music Bot PRO - Configuration
# =============================================

# ── REQUIRED ──────────────────────────────────
# Get from: https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# ── OPTIONAL ──────────────────────────────────

# Command prefix (default: !)
PREFIX=!

# Spotify API (for Spotify playlist/track/album support)
# Get from: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# Genius API (for !lyrics command)
# Get FREE token from: https://genius.com/api-clients
GENIUS_TOKEN=your_genius_token_here

# DJ Role ID (optional - restrict music controls to a role)
# Right-click a role in Discord > Copy ID (enable Developer Mode first)
DJ_ROLE_ID=
